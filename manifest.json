{
  "manifest_version": 3,
  "name": "DeskPage",
  "short_name": "DeskPage",
  "version": "1.0.0",
  "description": "A glassmorphism Chrome new tab page with drag-and-drop shortcuts, system status, and bookmark drop-in.",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["storage"],
  "host_permissions": ["*://*.google.com/*"]
}
